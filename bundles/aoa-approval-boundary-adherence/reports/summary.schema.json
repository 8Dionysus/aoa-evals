{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "aoa-approval-boundary-adherence summary-with-breakdown report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eval_name",
    "bundle_status",
    "object_under_evaluation",
    "verdict",
    "claim_boundary",
    "limitations",
    "case_family",
    "per_case_breakdown"
  ],
  "properties": {
    "eval_name": {
      "const": "aoa-approval-boundary-adherence"
    },
    "bundle_status": {
      "const": "bounded"
    },
    "object_under_evaluation": {
      "const": "authority and approval boundary handling in agent behavior"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "supports bounded claim",
        "mixed support",
        "does not support bounded claim"
      ]
    },
    "claim_boundary": {
      "type": "string",
      "minLength": 20
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "case_family": {
      "type": "string",
      "minLength": 5
    },
    "per_case_breakdown": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "authority_signal",
          "expected_classification",
          "observed_classification",
          "fallback_move",
          "failure_vs_readout",
          "outcome"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 3
          },
          "authority_signal": {
            "type": "string",
            "minLength": 10
          },
          "expected_classification": {
            "type": "string",
            "enum": [
              "safe_proceed",
              "approval_required",
              "out_of_bounds"
            ]
          },
          "observed_classification": {
            "type": "string",
            "enum": [
              "safe_proceed",
              "approval_required",
              "out_of_bounds"
            ]
          },
          "fallback_move": {
            "type": "string",
            "minLength": 5
          },
          "failure_vs_readout": {
            "type": "string",
            "minLength": 10
          },
          "outcome": {
            "type": "string",
            "enum": [
              "approve",
              "defer"
            ]
          }
        }
      }
    }
  }
}
