{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "aoa-artifact-review-rubric summary-with-breakdown report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eval_name",
    "bundle_status",
    "object_under_evaluation",
    "verdict",
    "claim_boundary",
    "limitations",
    "case_family",
    "per_case_breakdown"
  ],
  "properties": {
    "eval_name": {
      "const": "aoa-artifact-review-rubric"
    },
    "bundle_status": {
      "const": "bounded"
    },
    "object_under_evaluation": {
      "const": "produced artifact quality on bounded agent change tasks"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "supports bounded claim",
        "mixed support",
        "does not support bounded claim"
      ]
    },
    "claim_boundary": {
      "type": "string",
      "minLength": 20
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "case_family": {
      "type": "string",
      "minLength": 5
    },
    "per_case_breakdown": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "task_fit",
          "coherence",
          "completeness",
          "reviewability",
          "failure_vs_readout",
          "outcome"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 3
          },
          "task_fit": {
            "type": "string",
            "minLength": 3
          },
          "coherence": {
            "type": "string",
            "minLength": 3
          },
          "completeness": {
            "type": "string",
            "minLength": 3
          },
          "reviewability": {
            "type": "string",
            "minLength": 3
          },
          "failure_vs_readout": {
            "type": "string",
            "minLength": 10
          },
          "outcome": {
            "type": "string",
            "enum": [
              "approve",
              "defer"
            ]
          }
        }
      }
    }
  }
}
