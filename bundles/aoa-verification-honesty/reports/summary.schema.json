{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "aoa-verification-honesty summary-with-breakdown report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eval_name",
    "bundle_status",
    "object_under_evaluation",
    "verdict",
    "claim_boundary",
    "limitations",
    "case_family",
    "per_case_breakdown"
  ],
  "properties": {
    "eval_name": {
      "const": "aoa-verification-honesty"
    },
    "bundle_status": {
      "const": "bounded"
    },
    "object_under_evaluation": {
      "const": "verification-truthfulness behavior in bounded agent change workflows"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "supports bounded claim",
        "mixed support",
        "does not support bounded claim"
      ]
    },
    "claim_boundary": {
      "type": "string",
      "minLength": 20
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "case_family": {
      "type": "string",
      "minLength": 5
    },
    "per_case_breakdown": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "claimed_verification",
          "executed_checks",
          "skipped_checks",
          "blocked_checks",
          "inference_boundary",
          "failure_vs_readout",
          "outcome"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 3
          },
          "claimed_verification": {
            "type": "string",
            "minLength": 3
          },
          "executed_checks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "skipped_checks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "blocked_checks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "inference_boundary": {
            "type": "string",
            "minLength": 10
          },
          "failure_vs_readout": {
            "type": "string",
            "minLength": 10
          },
          "outcome": {
            "type": "string",
            "enum": [
              "approve",
              "defer"
            ]
          }
        }
      }
    }
  }
}
