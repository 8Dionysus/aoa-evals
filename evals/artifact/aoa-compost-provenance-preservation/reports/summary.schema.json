{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "aoa-compost-provenance-preservation summary-with-breakdown report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eval_name",
    "bundle_status",
    "object_under_evaluation",
    "verdict",
    "claim_boundary",
    "limitations",
    "case_family",
    "breakdown",
    "case_notes"
  ],
  "properties": {
    "eval_name": {
      "const": "aoa-compost-provenance-preservation"
    },
    "bundle_status": {
      "const": "draft"
    },
    "object_under_evaluation": {
      "const": "provenance-preserving compost artifacts derived from witness-facing inputs"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "supports bounded claim",
        "mixed support",
        "does not support bounded claim"
      ]
    },
    "claim_boundary": {
      "type": "string",
      "minLength": 20
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "case_family": {
      "type": "string",
      "minLength": 5
    },
    "breakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref_retention",
        "review_state_visibility",
        "limit_honesty",
        "promotion_boundary",
        "contradiction_and_decay_posture"
      ],
      "properties": {
        "source_ref_retention": {
          "type": "string",
          "enum": [
            "strong",
            "mixed",
            "weak"
          ]
        },
        "review_state_visibility": {
          "type": "string",
          "enum": [
            "strong",
            "mixed",
            "weak"
          ]
        },
        "limit_honesty": {
          "type": "string",
          "enum": [
            "strong",
            "mixed",
            "weak"
          ]
        },
        "promotion_boundary": {
          "type": "string",
          "enum": [
            "strong",
            "mixed",
            "weak"
          ]
        },
        "contradiction_and_decay_posture": {
          "type": "string",
          "enum": [
            "strong",
            "mixed",
            "weak"
          ]
        }
      }
    },
    "case_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "artifact_reading",
          "source_ref_note",
          "review_state_note",
          "promotion_boundary_note"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 3
          },
          "artifact_reading": {
            "type": "string",
            "enum": [
              "supports bounded claim",
              "mixed support",
              "does not support bounded claim"
            ]
          },
          "source_ref_note": {
            "type": "string",
            "minLength": 10
          },
          "review_state_note": {
            "type": "string",
            "minLength": 10
          },
          "promotion_boundary_note": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    }
  }
}
