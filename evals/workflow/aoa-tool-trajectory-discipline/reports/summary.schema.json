{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "aoa-tool-trajectory-discipline summary-with-breakdown report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eval_name",
    "bundle_status",
    "object_under_evaluation",
    "verdict",
    "claim_boundary",
    "limitations",
    "case_family",
    "per_case_breakdown"
  ],
  "properties": {
    "eval_name": {
      "const": "aoa-tool-trajectory-discipline"
    },
    "bundle_status": {
      "const": "bounded"
    },
    "object_under_evaluation": {
      "const": "tool-use trajectory discipline in bounded agent change workflows"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "supports bounded claim",
        "mixed support",
        "does not support bounded claim"
      ]
    },
    "claim_boundary": {
      "type": "string",
      "minLength": 20
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "case_family": {
      "type": "string",
      "minLength": 5
    },
    "per_case_breakdown": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "why_path_matters",
          "trajectory_reading",
          "omission_or_churn_note",
          "failure_vs_readout",
          "outcome"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 3
          },
          "why_path_matters": {
            "type": "string",
            "minLength": 10
          },
          "trajectory_reading": {
            "type": "string",
            "enum": [
              "strong",
              "mixed",
              "weak"
            ]
          },
          "omission_or_churn_note": {
            "type": "string",
            "minLength": 10
          },
          "failure_vs_readout": {
            "type": "string",
            "minLength": 10
          },
          "outcome": {
            "type": "string",
            "enum": [
              "approve",
              "defer"
            ]
          }
        }
      }
    }
  }
}
