{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-evals/mechanics/audit/parts/artifact-verdict-hooks/schemas/artifact-to-verdict-hook.schema.json",
  "title": "aoa-evals artifact to verdict hook",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_type",
    "hook_id",
    "playbook_id",
    "eval_anchor",
    "verdict_bundle_ref",
    "artifact_inputs",
    "artifact_contract_refs",
    "trace_surfaces",
    "verification_surface",
    "contract_test_refs",
    "report_expectation"
  ],
  "properties": {
    "surface_type": {
      "type": "string",
      "const": "artifact_to_verdict_hook"
    },
    "hook_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 3
    },
    "playbook_id": {
      "type": "string",
      "pattern": "^AOA-P-[0-9]{4}$"
    },
    "eval_anchor": {
      "type": "string",
      "pattern": "^aoa-[a-z0-9-]+$"
    },
    "verdict_bundle_ref": {
      "type": "string",
      "minLength": 1
    },
    "artifact_inputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifact_contract_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "trace_surfaces": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verification_surface": {
      "type": "string",
      "minLength": 1
    },
    "contract_test_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "report_expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_format",
        "verdict_shape",
        "review_required"
      ],
      "properties": {
        "report_format": {
          "type": "string",
          "minLength": 1
        },
        "verdict_shape": {
          "type": "string",
          "minLength": 1
        },
        "review_required": {
          "type": "boolean"
        }
      }
    },
    "runtime_policy_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_owner",
        "enforcement_posture",
        "authorization_artifacts",
        "approval_artifacts",
        "fallback_or_rollback_artifacts",
        "runtime_review_required",
        "forbidden_claims"
      ],
      "properties": {
        "policy_owner": {
          "type": "string",
          "const": "runtime_or_route_owner"
        },
        "enforcement_posture": {
          "type": "string",
          "const": "candidate_metadata_only_not_runtime_enforcement"
        },
        "authorization_artifacts": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "approval_artifacts": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fallback_or_rollback_artifacts": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "runtime_review_required": {
          "type": "boolean",
          "const": true
        },
        "forbidden_claims": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
