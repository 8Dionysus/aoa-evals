{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents-of-abyss.local/aoa-evals/schemas/aoa-eval-candidate-packet.schema.json",
  "title": "AoA Eval Candidate Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "candidate_only",
    "proof_authority",
    "promotion_allowed",
    "source_kind",
    "source_ref",
    "observed_at_utc",
    "trigger_class_id",
    "task_pressure",
    "expected_aoa_eval_route",
    "actual_trajectory",
    "first_failure",
    "consequence",
    "owner_surface_refs",
    "evidence_refs",
    "freshness_refs",
    "privacy_boundary",
    "existing_surface_check",
    "routing_rubric",
    "evaluator_fit",
    "candidate_state",
    "candidate_state_reason",
    "promotion_forbidden_until",
    "forbidden_effects",
    "next_step"
  ],
  "properties": {
    "schema_version": {
      "const": "aoa_eval_candidate_packet_v1"
    },
    "packet_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,160}$"
    },
    "candidate_only": {
      "const": true
    },
    "proof_authority": {
      "const": false
    },
    "promotion_allowed": {
      "const": false
    },
    "source_kind": {
      "enum": [
        "session_episode",
        "runtime_export",
        "local_eval_port",
        "validator_gap",
        "quest_lineage",
        "support_registry",
        "manual_review_note"
      ]
    },
    "source_ref": {
      "type": "string",
      "minLength": 1
    },
    "observed_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "trigger_class_id": {
      "type": "string",
      "minLength": 1
    },
    "task_pressure": {
      "type": "string",
      "minLength": 1
    },
    "expected_aoa_eval_route": {
      "enum": [
        "select",
        "apply",
        "local_need",
        "design",
        "session_candidate",
        "freshness_sentinel",
        "runtime_owner",
        "trigger_design"
      ]
    },
    "actual_trajectory": {
      "type": "string",
      "minLength": 1
    },
    "first_failure": {
      "type": "string",
      "minLength": 1
    },
    "consequence": {
      "type": "string",
      "minLength": 1
    },
    "owner_surface_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "freshness_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "privacy_boundary": {
      "type": "string",
      "minLength": 1
    },
    "existing_surface_check": {
      "type": "string",
      "minLength": 1
    },
    "routing_rubric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger_strength",
        "owner_surface_clarity",
        "consequence_severity",
        "repeatability",
        "freshness_dependency",
        "existing_eval_fit",
        "privacy_raw_evidence_boundary"
      ],
      "properties": {
        "trigger_strength": {
          "$ref": "#/$defs/score"
        },
        "owner_surface_clarity": {
          "$ref": "#/$defs/score"
        },
        "consequence_severity": {
          "$ref": "#/$defs/score"
        },
        "repeatability": {
          "$ref": "#/$defs/score"
        },
        "freshness_dependency": {
          "$ref": "#/$defs/score"
        },
        "existing_eval_fit": {
          "$ref": "#/$defs/score"
        },
        "privacy_raw_evidence_boundary": {
          "$ref": "#/$defs/score"
        }
      }
    },
    "evaluator_fit": {
      "enum": [
        "deterministic_validator",
        "unit_contract_property_test",
        "trace_trajectory_eval",
        "human_review_rubric",
        "local_intake",
        "skill_trigger_design",
        "runtime_smoke",
        "central_bundle_design",
        "reject_no_eval_fit"
      ]
    },
    "candidate_state": {
      "enum": [
        "observed",
        "needs_owner_review",
        "duplicate_existing_eval",
        "local_only",
        "central_draft",
        "rejected",
        "deferred",
        "accepted"
      ]
    },
    "candidate_state_reason": {
      "type": "string",
      "minLength": 1
    },
    "promotion_forbidden_until": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_effects": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_step": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2
    }
  }
}
