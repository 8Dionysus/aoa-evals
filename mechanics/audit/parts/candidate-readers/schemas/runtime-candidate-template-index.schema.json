{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-evals/main/mechanics/audit/parts/candidate-readers/schemas/runtime-candidate-template-index.schema.json",
  "title": "aoa-evals runtime candidate template index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "layer",
    "source_of_truth",
    "templates"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "layer": {
      "type": "string",
      "const": "aoa-evals"
    },
    "source_of_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eval_catalog",
        "runtime_evidence_selection_examples",
        "artifact_to_verdict_hook_examples"
      ],
      "properties": {
        "eval_catalog": {
          "type": "string",
          "const": "generated/eval_catalog.min.json"
        },
        "runtime_evidence_selection_examples": {
          "type": "string",
          "const": "mechanics/audit/parts/selected-evidence-packets/examples/runtime_evidence_selection.*.example.json"
        },
        "artifact_to_verdict_hook_examples": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^mechanics/(audit/parts/artifact-verdict-hooks|checkpoint/parts/(a2a-summon-return|restartable-inquiry|self-agent-posture))/examples/artifact_to_verdict_hook\\.\\*\\.example\\.json$"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "template_kind",
          "template_name",
          "playbook_id",
          "eval_anchor",
          "verdict_bundle_ref",
          "required_runtime_artifacts",
          "runtime_policy_boundary",
          "memory_context_boundary",
          "review_required",
          "source_example_ref"
        ],
        "properties": {
          "template_kind": {
            "type": "string",
            "enum": [
              "runtime_evidence_selection",
              "artifact_to_verdict_hook"
            ]
          },
          "template_name": {
            "type": "string",
            "minLength": 3
          },
          "playbook_id": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^AOA-P-[0-9]{4}$"
          },
          "eval_anchor": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 3
          },
          "verdict_bundle_ref": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 3
          },
          "required_runtime_artifacts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "runtime_policy_boundary": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": false,
            "required": [
              "policy_owner",
              "enforcement_posture",
              "authorization_artifacts",
              "approval_artifacts",
              "fallback_or_rollback_artifacts",
              "runtime_review_required",
              "forbidden_claims"
            ],
            "properties": {
              "policy_owner": {
                "type": "string",
                "const": "runtime_or_route_owner"
              },
              "enforcement_posture": {
                "type": "string",
                "const": "candidate_metadata_only_not_runtime_enforcement"
              },
              "authorization_artifacts": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "approval_artifacts": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "fallback_or_rollback_artifacts": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "runtime_review_required": {
                "type": "boolean",
                "const": true
              },
              "forbidden_claims": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "memory_context_boundary": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": false,
            "required": [
              "memory_owner_repo",
              "consumer_posture",
              "allowed_influence",
              "provenance_refs",
              "freshness_refs",
              "retention_refs",
              "permission_refs",
              "authority_stop_lines",
              "review_required"
            ],
            "properties": {
              "memory_owner_repo": {
                "type": "string",
                "const": "aoa-memo"
              },
              "consumer_posture": {
                "type": "string",
                "const": "candidate_context_only_not_memory_authority"
              },
              "allowed_influence": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "provenance_refs": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "freshness_refs": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "retention_refs": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "permission_refs": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "authority_stop_lines": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "review_required": {
                "type": "boolean",
                "const": true
              }
            }
          },
          "review_required": {
            "type": "boolean"
          },
          "source_example_ref": {
            "type": "string",
            "pattern": "^mechanics/(audit/parts/(selected-evidence-packets/examples/runtime_evidence_selection|artifact-verdict-hooks/examples/artifact_to_verdict_hook)|checkpoint/parts/(a2a-summon-return|restartable-inquiry|self-agent-posture)/examples/artifact_to_verdict_hook)\\..+\\.example\\.json$"
          }
        }
      }
    }
  }
}
