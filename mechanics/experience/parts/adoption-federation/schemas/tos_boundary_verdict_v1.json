{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/schemas/tos_boundary_verdict_v1.json",
  "title": "tos_boundary_verdict_v1",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "id",
    "status",
    "summary",
    "evidence_refs",
    "payload",
    "owner_repo"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "kind": {
      "type": "string",
      "const": "tos_boundary_verdict"
    },
    "id": {
      "type": "string",
      "minLength": 3
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "captured",
        "candidate",
        "review",
        "approved",
        "blocked",
        "rejected",
        "promoted",
        "active",
        "retired",
        "scheduled",
        "passed",
        "failed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "payload": {
      "type": "object",
      "required": [
        "direct_write_blocked",
        "dossier_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "direct_write_blocked": {
          "type": "boolean",
          "const": true
        },
        "dossier_allowed": {
          "type": "boolean",
          "const": true
        }
      }
    }
  },
  "additionalProperties": false
}
