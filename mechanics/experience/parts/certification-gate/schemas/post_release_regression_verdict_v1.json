{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "post_release_regression_verdict",
  "type": "object",
  "description": "post_release_regression_verdict schema for AoA experience deployment watchtower v0.5.",
  "required": [
    "verdict_id",
    "release_id",
    "regression_detected",
    "families",
    "recommended_action"
  ],
  "properties": {
    "verdict_id": {
      "type": "string"
    },
    "release_id": {
      "type": "string"
    },
    "regression_detected": {
      "type": "boolean"
    },
    "families": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_action": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
