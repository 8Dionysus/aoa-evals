{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-evals/mechanics/proof-object/parts/eval-authoring/schemas/eval-archetype-registry.schema.json",
  "title": "aoa-evals eval forge archetype registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "authority_boundary",
    "checked_at_utc",
    "source_surfaces",
    "archetypes"
  ],
  "properties": {
    "schema_version": {
      "const": "eval_forge_archetype_registry_v1"
    },
    "authority_boundary": {
      "type": "string",
      "minLength": 20
    },
    "checked_at_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "source_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "archetypes": {
      "type": "array",
      "minItems": 18,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "route_kind",
          "signals",
          "use_when",
          "do_not_use_when",
          "required_evidence",
          "required_owner_surface",
          "grader_family",
          "fixture_shape",
          "positive_negative_case_expectation",
          "repeatability_requirements",
          "anti_gaming_risks",
          "local_vs_central_route",
          "validation_route",
          "example_refs"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "label": {
            "type": "string",
            "minLength": 3
          },
          "route_kind": {
            "type": "string",
            "enum": [
              "validator",
              "test",
              "property",
              "trajectory",
              "tool",
              "state",
              "response",
              "freshness",
              "boundary",
              "local-intake",
              "local-suite",
              "skill-trigger",
              "runtime-smoke",
              "human-rubric",
              "llm-judge",
              "central-proof",
              "comparison",
              "longitudinal"
            ]
          },
          "signals": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "string",
              "minLength": 2
            }
          },
          "use_when": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 8
            }
          },
          "do_not_use_when": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 8
            }
          },
          "required_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 4
            }
          },
          "required_owner_surface": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "grader_family": {
            "type": "string",
            "minLength": 5
          },
          "fixture_shape": {
            "type": "string",
            "minLength": 5
          },
          "positive_negative_case_expectation": {
            "type": "string",
            "minLength": 10
          },
          "repeatability_requirements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 5
            }
          },
          "anti_gaming_risks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 5
            }
          },
          "local_vs_central_route": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "target",
              "owner_repo",
              "route_key"
            ],
            "properties": {
              "target": {
                "type": "string",
                "enum": [
                  "local",
                  "central",
                  "stronger-owner",
                  "advisory"
                ]
              },
              "owner_repo": {
                "type": "string",
                "minLength": 3
              },
              "route_key": {
                "type": "string",
                "minLength": 3
              }
            }
          },
          "validation_route": {
            "type": "string",
            "minLength": 5
          },
          "example_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            }
          }
        }
      }
    }
  }
}
