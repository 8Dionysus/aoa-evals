{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-evals/mechanics/proof-object/parts/eval-authoring/schemas/eval-need.schema.json",
  "title": "aoa-evals eval_need_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "proof_question",
    "origin_need",
    "summary",
    "object_under_evaluation",
    "category",
    "claim_type",
    "baseline_mode",
    "report_format",
    "authoring_route",
    "expected_use_when",
    "blind_spot_notes"
  ],
  "properties": {
    "schema_version": {
      "const": "eval_need_v1"
    },
    "name": {
      "type": "string",
      "pattern": "^aoa-[a-z0-9-]+$"
    },
    "proof_question": {
      "type": "string",
      "minLength": 12
    },
    "origin_need": {
      "type": "string",
      "minLength": 12
    },
    "summary": {
      "type": "string",
      "minLength": 12
    },
    "object_under_evaluation": {
      "type": "string",
      "minLength": 3
    },
    "category": {
      "type": "string",
      "enum": [
        "capability",
        "workflow",
        "boundary",
        "artifact",
        "regression",
        "comparative",
        "longitudinal",
        "stress"
      ]
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "bounded",
        "comparative",
        "regression",
        "longitudinal"
      ]
    },
    "baseline_mode": {
      "type": "string",
      "enum": [
        "none",
        "fixed-baseline",
        "previous-version",
        "peer-compare",
        "longitudinal-window"
      ]
    },
    "report_format": {
      "type": "string",
      "enum": [
        "summary",
        "summary-with-breakdown",
        "comparative-summary"
      ]
    },
    "verdict_shape": {
      "type": "string",
      "enum": [
        "pass-fail",
        "categorical",
        "scalar-with-interpretation",
        "comparative",
        "mixed"
      ]
    },
    "authoring_route": {
      "type": "string",
      "enum": [
        "existing_eval_route",
        "candidate_evidence_packet",
        "quest_record",
        "new_draft_bundle"
      ]
    },
    "expected_use_when": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "blind_spot_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "related_eval_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^aoa-[a-z0-9-]+$"
      }
    },
    "candidate_evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "quest_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^AOA-EV-Q-[0-9]{4}$"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "comparison_surface": {
      "type": [
        "object",
        "null"
      ]
    },
    "technique_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "repo",
          "path"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AOA-T-(?:[0-9]{4}|PENDING-[A-Z0-9-]+)$"
          },
          "repo": {
            "type": "string",
            "minLength": 3
          },
          "path": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "skill_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "repo",
          "path"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^(aoa|abyss|atm10)-[a-z0-9-]+$"
          },
          "repo": {
            "type": "string",
            "minLength": 3
          },
          "path": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "capability_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "registry_repo",
          "registry_path",
          "target_owner"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9.-]+$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "adapter",
              "capability",
              "guard",
              "human-gate",
              "mode",
              "skill",
              "tool",
              "workflow"
            ]
          },
          "registry_repo": {
            "type": "string",
            "minLength": 3
          },
          "registry_path": {
            "type": "string",
            "minLength": 3
          },
          "target_owner": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "baseline_mode": {
            "const": "none"
          }
        }
      },
      "then": {
        "properties": {
          "comparison_surface": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authoring_route": {
            "const": "existing_eval_route"
          }
        }
      },
      "then": {
        "required": [
          "related_eval_refs"
        ],
        "properties": {
          "related_eval_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authoring_route": {
            "const": "candidate_evidence_packet"
          }
        }
      },
      "then": {
        "required": [
          "candidate_evidence_refs"
        ],
        "properties": {
          "candidate_evidence_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authoring_route": {
            "const": "quest_record"
          }
        }
      },
      "then": {
        "required": [
          "quest_refs"
        ],
        "properties": {
          "quest_refs": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
