{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "unlock_proof_catalog_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proofs",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "const": "unlock_proof_catalog_v1"
    },
    "proofs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_version",
          "proof_id",
          "subject_ref",
          "subject_kind",
          "review_scope",
          "verdict",
          "unlock_candidates",
          "evidence_refs",
          "evaluator_ref",
          "reviewed_at",
          "public_safe"
        ],
        "properties": {
          "schema_version": {
            "const": "unlock_proof_v1"
          },
          "proof_id": {
            "type": "string",
            "minLength": 1
          },
          "subject_ref": {
            "type": "string",
            "minLength": 1
          },
          "subject_kind": {
            "enum": [
              "agent_build",
              "party_template",
              "campaign_lane",
              "artifact_attunement"
            ]
          },
          "review_scope": {
            "enum": [
              "quest_scoped",
              "route_scoped",
              "campaign_scoped"
            ]
          },
          "verdict": {
            "enum": [
              "grant",
              "gated_grant",
              "hold",
              "revoke"
            ]
          },
          "related_refs": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "quest_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "playbook_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "progression_evidence_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "chronicle_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "unlock_candidates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "unlock_id",
                "unlock_kind",
                "disposition",
                "confidence",
                "evidence_refs"
              ],
              "properties": {
                "unlock_id": {
                  "type": "string",
                  "minLength": 1
                },
                "unlock_kind": {
                  "enum": [
                    "ability",
                    "feat",
                    "difficulty_ceiling",
                    "risk_ceiling",
                    "cohort_pattern",
                    "party_template",
                    "campaign_lane",
                    "artifact_attunement",
                    "control_mode"
                  ]
                },
                "disposition": {
                  "enum": [
                    "grant",
                    "gated_grant",
                    "hold",
                    "revoke"
                  ]
                },
                "confidence": {
                  "enum": [
                    "low",
                    "medium",
                    "high"
                  ]
                },
                "evidence_refs": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "conditions": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "cautions": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "notes": {
                  "type": "string"
                }
              }
            }
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "evaluator_ref": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string"
          },
          "reviewed_at": {
            "type": "string",
            "format": "date"
          },
          "public_safe": {
            "type": "boolean"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
