{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-evals/schemas/eval-frontmatter.schema.json",
  "title": "aoa-evals EVAL.md frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "category",
    "status",
    "summary",
    "object_under_evaluation",
    "claim_type",
    "baseline_mode",
    "report_format",
    "technique_dependencies",
    "skill_dependencies"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^aoa-[a-z0-9-]+$"
    },
    "category": {
      "type": "string",
      "enum": [
        "capability",
        "workflow",
        "boundary",
        "artifact",
        "regression",
        "comparative",
        "longitudinal",
        "stress"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "bounded",
        "portable",
        "baseline",
        "canonical",
        "deprecated"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 10
    },
    "object_under_evaluation": {
      "type": "string",
      "minLength": 3
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "bounded",
        "comparative",
        "regression",
        "longitudinal"
      ]
    },
    "baseline_mode": {
      "type": "string",
      "enum": [
        "none",
        "fixed-baseline",
        "previous-version",
        "peer-compare",
        "longitudinal-window"
      ]
    },
    "report_format": {
      "type": "string",
      "enum": [
        "summary",
        "summary-with-breakdown",
        "comparative-summary"
      ]
    },
    "technique_dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^AOA-T-(?:[0-9]{4}|PENDING-[A-Z0-9-]+)$"
      }
    },
    "skill_dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(aoa|abyss|atm10)-[a-z0-9-]+$"
      }
    }
  }
}
