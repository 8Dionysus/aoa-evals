{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-evals/schemas/eval-manifest.schema.json",
  "title": "aoa-evals eval.yaml manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "category",
    "status",
    "object_under_evaluation",
    "claim_type",
    "baseline_mode",
    "verdict_shape",
    "report_format",
    "maturity_score",
    "rigor_level",
    "repeatability",
    "portability_level",
    "review_required",
    "validation_strength",
    "export_ready",
    "blind_spot_disclosure",
    "score_interpretation_bound",
    "technique_dependencies",
    "skill_dependencies",
    "relations",
    "evidence"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^aoa-[a-z0-9-]+$"
    },
    "category": {
      "type": "string",
      "enum": [
        "capability",
        "workflow",
        "boundary",
        "artifact",
        "regression",
        "comparative",
        "longitudinal",
        "stress"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "bounded",
        "portable",
        "baseline",
        "canonical",
        "deprecated"
      ]
    },
    "object_under_evaluation": {
      "type": "string",
      "minLength": 3
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "bounded",
        "comparative",
        "regression",
        "longitudinal"
      ]
    },
    "baseline_mode": {
      "type": "string",
      "enum": [
        "none",
        "fixed-baseline",
        "previous-version",
        "peer-compare",
        "longitudinal-window"
      ]
    },
    "verdict_shape": {
      "type": "string",
      "enum": [
        "pass-fail",
        "categorical",
        "scalar-with-interpretation",
        "comparative",
        "mixed"
      ]
    },
    "report_format": {
      "type": "string",
      "enum": [
        "summary",
        "summary-with-breakdown",
        "comparative-summary"
      ]
    },
    "maturity_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "rigor_level": {
      "type": "string",
      "enum": [
        "light",
        "bounded",
        "strict"
      ]
    },
    "repeatability": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high"
      ]
    },
    "portability_level": {
      "type": "string",
      "enum": [
        "local-shaped",
        "portable",
        "broad"
      ]
    },
    "review_required": {
      "type": "boolean"
    },
    "validation_strength": {
      "type": "string",
      "enum": [
        "baseline",
        "source_backed",
        "cross_context"
      ]
    },
    "export_ready": {
      "type": "boolean"
    },
    "blind_spot_disclosure": {
      "type": "string",
      "enum": [
        "required-and-present",
        "partial",
        "missing"
      ]
    },
    "score_interpretation_bound": {
      "type": "string",
      "enum": [
        "explicit",
        "partial",
        "missing"
      ]
    },
    "comparison_surface": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "shared_family_path": {
          "type": "string",
          "minLength": 3
        },
        "paired_readout_path": {
          "type": "string",
          "minLength": 3
        },
        "integrity_sidecar": {
          "type": "string",
          "pattern": "^aoa-[a-z0-9-]+$"
        },
        "selection_question": {
          "type": "string",
          "minLength": 10
        },
        "anchor_surface": {
          "type": "string",
          "pattern": "^aoa-[a-z0-9-]+$"
        },
        "baseline_target_label": {
          "type": "string",
          "minLength": 5
        },
        "peer_surfaces": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^aoa-[a-z0-9-]+$"
          }
        },
        "matched_surface": {
          "type": "string",
          "minLength": 5
        },
        "window_family_label": {
          "type": "string",
          "minLength": 5
        }
      }
    },
    "technique_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "repo",
          "path"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AOA-T-(?:[0-9]{4}|PENDING-[A-Z0-9-]+)$"
          },
          "repo": {
            "type": "string",
            "minLength": 3
          },
          "path": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "skill_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "repo",
          "path"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^(aoa|abyss|atm10)-[a-z0-9-]+$"
          },
          "repo": {
            "type": "string",
            "minLength": 3
          },
          "path": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "target"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "requires",
              "complements",
              "supersedes",
              "conflicts_with",
              "used_together_for",
              "derived_from",
              "checks_integrity_of"
            ]
          },
          "target": {
            "type": "string",
            "pattern": "^aoa-[a-z0-9-]+$"
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "origin_need",
              "portable_review",
              "baseline_readiness",
              "canonical_readiness",
              "integrity_check",
              "support_note"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "baseline_mode": {
            "const": "none"
          }
        }
      },
      "then": {
        "properties": {
          "comparison_surface": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "baseline_mode": {
            "enum": [
              "fixed-baseline",
              "previous-version"
            ]
          }
        }
      },
      "then": {
        "required": [
          "comparison_surface"
        ],
        "properties": {
          "comparison_surface": {
            "type": "object",
            "required": [
              "shared_family_path",
              "paired_readout_path",
              "integrity_sidecar",
              "selection_question",
              "anchor_surface",
              "baseline_target_label"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "baseline_mode": {
            "const": "peer-compare"
          }
        }
      },
      "then": {
        "required": [
          "comparison_surface"
        ],
        "properties": {
          "comparison_surface": {
            "type": "object",
            "required": [
              "shared_family_path",
              "paired_readout_path",
              "integrity_sidecar",
              "selection_question",
              "peer_surfaces",
              "matched_surface"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "baseline_mode": {
            "const": "longitudinal-window"
          }
        }
      },
      "then": {
        "required": [
          "comparison_surface"
        ],
        "properties": {
          "comparison_surface": {
            "type": "object",
            "required": [
              "shared_family_path",
              "paired_readout_path",
              "integrity_sidecar",
              "selection_question",
              "anchor_surface",
              "window_family_label"
            ]
          }
        }
      }
    }
  ]
}
