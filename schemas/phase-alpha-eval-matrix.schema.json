{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-evals/schemas/phase-alpha-eval-matrix.schema.json",
  "title": "aoa-evals phase alpha eval matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "layer",
    "phase",
    "source_of_truth",
    "runtime_lanes",
    "verdict_interpretation",
    "runs"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "layer": {
      "const": "aoa-evals"
    },
    "phase": {
      "const": "alpha"
    },
    "source_of_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase_alpha_eval_plan",
        "phase_alpha_run_matrix",
        "trace_eval_hooks",
        "runtime_evidence_selection_examples"
      ],
      "properties": {
        "phase_alpha_eval_plan": {
          "const": "examples/phase_alpha_eval_matrix.example.json"
        },
        "phase_alpha_run_matrix": {
          "const": "repo:aoa-playbooks/generated/phase_alpha_run_matrix.min.json"
        },
        "trace_eval_hooks": {
          "const": "examples/artifact_to_verdict_hook.*.example.json"
        },
        "runtime_evidence_selection_examples": {
          "const": "examples/runtime_evidence_selection.*.example.json"
        }
      }
    },
    "runtime_lanes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary",
        "control"
      ],
      "properties": {
        "primary": {
          "type": "string",
          "minLength": 1
        },
        "control": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "verdict_interpretation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pass",
        "fail",
        "blocked"
      ],
      "properties": {
        "pass": {
          "type": "string",
          "minLength": 1
        },
        "fail": {
          "type": "string",
          "minLength": 1
        },
        "blocked": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "run_id",
          "sequence",
          "playbook_id",
          "playbook_name",
          "runtime_lane",
          "optional_control_path_rerun",
          "required_evals"
        ],
        "properties": {
          "run_id": {
            "type": "string",
            "minLength": 1
          },
          "sequence": {
            "type": "integer",
            "minimum": 1
          },
          "playbook_id": {
            "type": "string",
            "pattern": "^AOA-P-[0-9]{4}$"
          },
          "playbook_name": {
            "type": "string",
            "minLength": 1
          },
          "runtime_lane": {
            "type": "string",
            "enum": [
              "primary",
              "control"
            ]
          },
          "optional_control_path_rerun": {
            "type": "boolean"
          },
          "required_evals": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "eval_anchor",
                "evidence_refs"
              ],
              "properties": {
                "eval_anchor": {
                  "type": "string",
                  "pattern": "^aoa-[a-z0-9-]+$"
                },
                "evidence_refs": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
