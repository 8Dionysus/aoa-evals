{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-evals/schemas/runner-contract.schema.json",
  "title": "aoa-evals runner contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "runner_surface_path",
    "inputs",
    "report_schema_path",
    "report_example_path"
  ],
  "properties": {
    "contract_version": {
      "const": 1
    },
    "runner_surface_path": {
      "type": "string",
      "minLength": 3
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "fixture_contract_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "scorer_helper_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "report_schema_path": {
      "type": "string",
      "minLength": 3
    },
    "report_example_path": {
      "type": "string",
      "minLength": 3
    },
    "paired_readout_path": {
      "type": "string",
      "minLength": 3
    },
    "additional_paired_readout_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "validation_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  }
}
