{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-evals/schemas/stats-event-envelope.schema.json",
  "title": "aoa-evals stats event envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_kind",
    "event_id",
    "observed_at",
    "run_ref",
    "session_ref",
    "actor_ref",
    "object_ref",
    "evidence_refs",
    "payload"
  ],
  "properties": {
    "event_kind": {
      "type": "string",
      "enum": [
        "skill_run_receipt",
        "technique_trace_receipt",
        "eval_result_receipt",
        "harvest_packet_receipt",
        "decision_fork_receipt",
        "progression_delta_receipt",
        "repair_cycle_receipt",
        "automation_candidate_receipt"
      ]
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "run_ref": {
      "type": "string",
      "minLength": 1
    },
    "session_ref": {
      "type": "string",
      "minLength": 1
    },
    "actor_ref": {
      "type": "string",
      "minLength": 1
    },
    "object_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "kind",
        "id"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "ref"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "supersedes": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    }
  }
}
